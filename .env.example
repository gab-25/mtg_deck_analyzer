# Local development environment (without Docker).
# Copy this file to ".env" and adjust the values; it is loaded automatically
# when the web app starts. Real environment variables take precedence over it.
#
#   cp .env.example .env

# Database connection (any SQLAlchemy URL). Defaults to a local Postgres.
DATABASE_URL=postgresql+psycopg://mtg:mtg@localhost:5432/mtg
# For a quick, dependency-free run you can use a local SQLite file instead:
# DATABASE_URL=sqlite+pysqlite:///./mtg.db

# Google Gemini API key — optional; enables the strategic deck analysis.
GEMINI_API_KEY=

# Default target language for card names and analysis (e.g. en, it, es, fr, de).
# Can also be chosen per-deck in the web form. Defaults to "en".
DEFAULT_LANG=en

# Server bind address, port and auto-reload (all optional).
HOST=0.0.0.0
PORT=8000
RELOAD=1
